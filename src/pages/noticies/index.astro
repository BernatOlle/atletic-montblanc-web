---
import Layout from '../../layouts/Layout.astro';
import NewsCard from '../../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const noticies = await getCollection('noticies');
const sorted = noticies.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="Notícies" description="Notícies, resultats i comunicats del Club Atlètic Montblanc.">
  <section class="bg-club-dark text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14">
      <nav class="text-sm text-gray-400 mb-4">
        <a href="/" class="hover:text-white transition-colors">Inici</a>
        <span class="mx-2">/</span>
        <span class="text-white">Notícies</span>
      </nav>
      <h1 class="text-4xl font-extrabold">Notícies</h1>
      <p class="text-gray-300 text-lg mt-2">Resultats, comunicats i actualitat del club</p>
    </div>
  </section>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-14">
    <div class="flex flex-col gap-4">
      {sorted.map(n => (
        <NewsCard
          title={n.data.title}
          date={n.data.date}
          excerpt={n.data.excerpt}
          href={`/noticies/${n.slug}`}
          image={n.data.image}
        />
      ))}
    </div>
  </div>
</Layout>
