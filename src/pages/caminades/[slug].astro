---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import { getCollection } from 'astro:content';
import { wikiloc } from '../../lib/races';

export async function getStaticPaths() {
  const caminades = await getCollection('caminades');
  return caminades.map(c => ({ params: { slug: c.slug }, props: { caminada: c } }));
}

const { caminada } = Astro.props;
const { Content } = await caminada.render();
const {
  title, date, distance, elevation, difficulty, duration, meetingPoint,
  image, photosUrl, routeUrl, featured,
} = caminada.data;

const formattedDate = date.toLocaleDateString('ca-ES', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
});
const isUpcoming = date >= new Date();

const difficultyBadge: Record<string, string> = {
  'fàcil':   'bg-green-100 text-green-800',
  'moderat': 'bg-yellow-100 text-yellow-800',
  'difícil': 'bg-red-100 text-red-800',
};

const mapSrc = routeUrl ? wikiloc(routeUrl) : null;
---

<Layout title={title} description={`Caminada del Club Atlètic Montblanc: ${title}`}>

  <!-- HERO -->
  <div class="relative bg-club-dark overflow-hidden min-h-[260px] flex items-end">
    {image ? (
      <img src={image} alt={title} class="absolute inset-0 w-full h-full object-cover opacity-25" />
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-green-900/40 to-club-dark"></div>
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-club-dark/80 to-transparent"></div>

    <div class="relative w-full max-w-4xl mx-auto px-4 sm:px-6 py-10">
      <nav class="text-sm text-gray-400 mb-4">
        <a href="/" class="hover:text-white transition-colors">Inici</a>
        <span class="mx-2">/</span>
        <a href="/caminades" class="hover:text-white transition-colors">Caminades</a>
        <span class="mx-2">/</span>
        <span class="text-white">{title}</span>
      </nav>

      <div class="flex flex-wrap items-center gap-2 mb-2">
        {isUpcoming ? (
          <span class="inline-flex items-center gap-1.5 bg-green-600 text-white text-xs font-bold px-3 py-1 rounded-full">
            <span class="h-1.5 w-1.5 bg-white rounded-full animate-pulse"></span>
            Pròxima caminada
          </span>
        ) : (
          <span class="inline-flex items-center gap-1.5 bg-white/15 text-white text-xs font-semibold px-3 py-1 rounded-full">
            <Icon name="check-circle" class="h-3.5 w-3.5" />
            Realitzada
          </span>
        )}
        {difficulty && (
          <span class={`text-xs font-semibold px-3 py-1 rounded-full capitalize ${difficultyBadge[difficulty]}`}>
            {difficulty}
          </span>
        )}
      </div>

      <h1 class="text-3xl sm:text-4xl font-extrabold text-white leading-tight">{title}</h1>
      <p class="text-gray-300 capitalize mt-1">{formattedDate}</p>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10 space-y-6">

    <!-- BLOC 1: Descripció -->
    <section class="bg-white rounded-2xl border border-club-beige p-7">
      <p class="text-xs font-bold text-primary uppercase tracking-widest mb-4">Descripció</p>
      <div class="prose prose-lg max-w-none text-club-mid leading-relaxed [&_strong]:text-club-dark [&_a]:text-primary">
        <Content />
      </div>
    </section>

    <!-- BLOC 2: Informació pràctica -->
    <section class="bg-club-light rounded-2xl p-7">
      <p class="text-xs font-bold text-primary uppercase tracking-widest mb-5">Informació pràctica</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
        {distance && (
          <div class="bg-white rounded-xl p-4 text-center">
            <Icon name="map" class="h-5 w-5 text-primary mx-auto mb-2" />
            <p class="text-2xl font-extrabold text-club-dark">{distance}</p>
            <p class="text-xs text-club-mid mt-0.5">km</p>
          </div>
        )}
        {elevation && (
          <div class="bg-white rounded-xl p-4 text-center">
            <Icon name="arrow-trending-up" class="h-5 w-5 text-primary mx-auto mb-2" />
            <p class="text-2xl font-extrabold text-club-dark">+{elevation}</p>
            <p class="text-xs text-club-mid mt-0.5">m desnivell</p>
          </div>
        )}
        {duration && (
          <div class="bg-white rounded-xl p-4 text-center">
            <Icon name="clock" class="h-5 w-5 text-primary mx-auto mb-2" />
            <p class="text-base font-extrabold text-club-dark">{duration}</p>
            <p class="text-xs text-club-mid mt-0.5">durada aprox.</p>
          </div>
        )}
        {difficulty && (
          <div class="bg-white rounded-xl p-4 text-center">
            <Icon name="bolt" class="h-5 w-5 text-primary mx-auto mb-2" />
            <p class="text-sm font-extrabold text-club-dark capitalize">{difficulty}</p>
            <p class="text-xs text-club-mid mt-0.5">dificultat</p>
          </div>
        )}
        {meetingPoint && (
          <div class="bg-white rounded-xl p-4 col-span-2 sm:col-span-1 flex flex-col items-center text-center">
            <Icon name="map-pin" class="h-5 w-5 text-primary mb-2" />
            <p class="text-sm font-bold text-club-dark leading-snug">{meetingPoint}</p>
            <p class="text-xs text-club-mid mt-0.5">punt de trobada</p>
          </div>
        )}
      </div>
    </section>

    <!-- BLOC 3: Recorregut + mapa -->
    {(mapSrc || routeUrl) && (
      <section class="bg-white rounded-2xl border border-club-beige p-7">
        <p class="text-xs font-bold text-primary uppercase tracking-widest mb-4">Recorregut</p>
        {mapSrc && (
          <div class="rounded-xl overflow-hidden border border-club-beige" style="height: 400px">
            <iframe
              src={mapSrc}
              width="100%"
              height="400"
              frameborder="0"
              scrolling="no"
              title={`Recorregut ${title}`}
              class="w-full h-full"
            ></iframe>
          </div>
        )}
        {routeUrl && (
          <a
            href={routeUrl}
            target="_blank"
            rel="noopener"
            class="mt-3 inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline"
          >
            <Icon name="map" class="h-4 w-4" />
            Veure recorregut a Wikiloc →
          </a>
        )}
      </section>
    )}

    <!-- BLOC 4: Accions -->
    <section>
      <div class="flex flex-wrap gap-3">
        {isUpcoming && (
          <a
            href="/contacte"
            class="inline-flex items-center gap-2.5 px-5 py-4 bg-green-700 text-white font-bold rounded-xl hover:bg-green-800 transition-colors"
          >
            <Icon name="users" class="h-5 w-5" />
            Vull apuntar-me
          </a>
        )}
        {photosUrl && (
          <a
            href={photosUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2.5 px-5 py-4 bg-club-dark text-white font-bold rounded-xl hover:bg-club-mid transition-colors"
          >
            <Icon name="camera" class="h-5 w-5" />
            Fotos de la caminada
          </a>
        )}
        <a
          href="/caminades"
          class="inline-flex items-center gap-2 px-5 py-4 border-2 border-club-beige text-club-mid font-semibold rounded-xl hover:border-primary hover:text-primary transition-colors text-sm"
        >
          <Icon name="arrow-left" class="h-4 w-4" />
          Totes les caminades
        </a>
      </div>
    </section>

  </div>
</Layout>
