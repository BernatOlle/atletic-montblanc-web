---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import { getCollection } from 'astro:content';
import { RACES, RACE_KEYS, type RaceKey } from '../../lib/races';

const allCarreres = await getCollection('carreres');
const today = new Date();

// Find the nearest upcoming race
const featuredEdition = allCarreres
  .filter(c => c.data.date >= today)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime())[0];

// For each of the 4 races, find the most recent edition (upcoming first, then past)
function latestEdition(raceKey: RaceKey) {
  const editions = allCarreres.filter(c => c.data.race === raceKey);
  const upcoming = editions.filter(c => c.data.date >= today).sort((a,b) => a.data.date.getTime() - b.data.date.getTime());
  const past = editions.filter(c => c.data.date < today).sort((a,b) => b.data.date.getTime() - a.data.date.getTime());
  return upcoming[0] ?? past[0] ?? null;
}
---

<Layout title="Carreres" description="Les 4 carreres populars del Club Atlètic Montblanc: Sant Joan, Sant Silvestre, Cursa de la Dona i Sant Josep.">

  <section class="bg-club-dark text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14">
      <nav class="text-sm text-gray-400 mb-4">
        <a href="/" class="hover:text-white transition-colors">Inici</a>
        <span class="mx-2">/</span>
        <span class="text-white">Carreres</span>
      </nav>
      <h1 class="text-4xl font-extrabold">Carreres</h1>
      <p class="text-gray-300 text-lg mt-2">Les 4 carreres populars del Club Atlètic Montblanc</p>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 space-y-14">

    <!-- PROPER ESDEVENIMENT -->
    {featuredEdition && (() => {
      const raceInfo = RACES[featuredEdition.data.race];
      const formattedDate = featuredEdition.data.date.toLocaleDateString('ca-ES', {
        weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
      });
      return (
        <section class="bg-club-dark text-white rounded-2xl overflow-hidden">
          <div class="p-8 sm:p-10">
            <span class="inline-flex items-center gap-1.5 bg-primary/20 border border-primary/40 text-primary text-xs font-semibold px-3 py-1.5 rounded-full mb-5">
              <span class="h-1.5 w-1.5 bg-primary rounded-full animate-pulse"></span>
              Proper esdeveniment
            </span>
            <h2 class="text-2xl sm:text-3xl font-extrabold mb-2">{featuredEdition.data.title}</h2>
            <p class="text-gray-300 capitalize mb-6">{formattedDate}</p>

            <div class="flex flex-wrap gap-5 text-sm text-gray-300 mb-8">
              {featuredEdition.data.distance && (
                <span class="flex items-center gap-1.5">
                  <Icon name="map" class="h-4 w-4 text-primary" />
                  {featuredEdition.data.distance} km
                </span>
              )}
              {featuredEdition.data.elevation && (
                <span class="flex items-center gap-1.5">
                  <Icon name="arrow-trending-up" class="h-4 w-4 text-primary" />
                  +{featuredEdition.data.elevation} m
                </span>
              )}
              {featuredEdition.data.location && (
                <span class="flex items-center gap-1.5">
                  <Icon name="map-pin" class="h-4 w-4 text-primary" />
                  {featuredEdition.data.location}
                </span>
              )}
            </div>

            <div class="flex flex-wrap gap-3">
              {featuredEdition.data.registrationUrl && (
                <a
                  href={featuredEdition.data.registrationUrl}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary text-white font-bold rounded-lg hover:bg-primary-dark transition-colors"
                >
                  <Icon name="ticket" class="h-4 w-4" />
                  Inscriu-te
                </a>
              )}
              {featuredEdition.data.reglamentUrl && (
                <a
                  href={featuredEdition.data.reglamentUrl}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/10 border border-white/20 text-white font-semibold rounded-lg hover:bg-white/20 transition-colors text-sm"
                >
                  <Icon name="document-text" class="h-4 w-4" />
                  Reglament
                </a>
              )}
              {featuredEdition.data.recorregutUrl && (
                <a
                  href={featuredEdition.data.recorregutUrl}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/10 border border-white/20 text-white font-semibold rounded-lg hover:bg-white/20 transition-colors text-sm"
                >
                  <Icon name="map" class="h-4 w-4" />
                  Recorregut
                </a>
              )}
              <a
                href={`/carreres/${featuredEdition.data.race}/${featuredEdition.data.year}`}
                class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/10 border border-white/20 text-white font-semibold rounded-lg hover:bg-white/20 transition-colors text-sm"
              >
                Veure detalls
                <Icon name="arrow-right" class="h-4 w-4" />
              </a>
            </div>
          </div>
        </section>
      );
    })()}

    <!-- 4 RACES GRID -->
    <section>
      <h2 class="text-2xl font-bold text-club-dark mb-6">Les nostres carreres</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {RACE_KEYS.map(raceKey => {
          const race = RACES[raceKey];
          const latest = latestEdition(raceKey);
          const isUpcoming = latest ? latest.data.date >= today : false;
          return (
            <a
              href={`/carreres/${raceKey}`}
              class="group bg-white border border-club-beige rounded-xl overflow-hidden hover:border-primary hover:shadow-lg transition-all duration-200"
            >
              <!-- Image placeholder -->
              <div class="h-32 bg-gradient-to-br from-club-beige to-club-light flex items-center justify-center relative">
                <Icon name="flag" class="h-12 w-12 text-club-mid opacity-20" />
                {isUpcoming && (
                  <span class="absolute top-3 right-3 inline-flex items-center gap-1 bg-primary text-white text-xs font-semibold px-2 py-0.5 rounded-full">
                    <span class="h-1.5 w-1.5 bg-white rounded-full animate-pulse"></span>
                    Pròxima
                  </span>
                )}
              </div>

              <div class="p-4">
                <p class="text-xs font-semibold text-primary uppercase tracking-wide mb-1">{race.month}</p>
                <h3 class="font-bold text-club-dark group-hover:text-primary transition-colors leading-snug mb-2">
                  {race.shortName}
                </h3>
                <p class="text-xs text-club-mid leading-relaxed mb-3">{race.description}</p>

                <div class="flex items-center gap-3 text-xs text-club-mid mb-3">
                  <span class="flex items-center gap-1">
                    <Icon name="map" class="h-3.5 w-3.5" />
                    {race.distance} km
                  </span>
                  <span class="flex items-center gap-1">
                    <Icon name="arrow-trending-up" class="h-3.5 w-3.5" />
                    +{race.elevation} m
                  </span>
                </div>

                <div class="flex items-center justify-between pt-2 border-t border-club-beige">
                  <span class="text-xs text-club-mid">
                    {latest ? `Edició ${latest.data.year}` : 'Veure edicions'}
                  </span>
                  <span class="text-xs font-semibold text-primary flex items-center gap-1 group-hover:gap-2 transition-all">
                    Veure
                    <Icon name="arrow-right" class="h-3.5 w-3.5" />
                  </span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </section>

  </div>
</Layout>
