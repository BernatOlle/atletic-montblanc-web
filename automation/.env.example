# Copia aquest fitxer a automation/.env i omple els valors.
# automation/.env MAI es committeja (ja està al .gitignore).

# Bot de Telegram (de @BotFather)
TELEGRAM_BOT_TOKEN=

# El teu chat ID (de @userinfobot). Només tu pots donar ordres.
TELEGRAM_ALLOWED_CHAT_ID=

# Linear (Settings → API → Personal API keys) i ID del team de la web
LINEAR_API_KEY=
LINEAR_TEAM_ID=
